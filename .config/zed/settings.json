{
  "agent_servers": {
    "qwen-code": {
      "type": "registry",
    },
  },
  "context_servers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "",
      },
    },
    "mcp-server-github": {
      "enabled": true,
      "settings": {
        "github_personal_access_token": "GITHUB_PERSONAL_ACCESS_TOKEN",
      },
    },
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "model_parameters": [],
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé - No Italics",
    "dark": "Catppuccin Frappé - No Italics",
  },
  "buffer_font_size": 25.5,
  "ui_font_size": 20,
  "agent_buffer_font_size": 20,
  "buffer_line_height": { "custom": 1 },
  "gutter": {
    "line_numbers": false,
    "runnables": false,
    "breakpoints": false,
    "folds": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // "title_bar": { "show": false },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "status_bar": { "experimental.show": false },
  "autosave": "on_focus_change",
  "languages": {
    "Python": {
      "format_on_save": "on",
      "language_servers": ["ruff", "ty"],
      "formatter": [
        { "language_server": { "name": "ruff" } },
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
      ],
    },
  },
}
