{
  // --- ui ---
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé - No Italics",
    "dark": "Catppuccin Frappé - No Italics",
  },
  "buffer_font_size": 21,
  "ui_font_size": 18,
  "agent_buffer_font_size": 15,
  "buffer_line_height": { "custom": 1 },
  "gutter": {
    "line_numbers": false,
    "runnables": false,
    "breakpoints": false,
    "folds": false,
  },
  // "title_bar": { "show": false },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
  },
  "toolbar": { "breadcrumbs": false, "quick_actions": false },
  "status_bar": { "experimental.show": false },
  "project_panel": {
    "bold_folder_labels": true,
    "indent_size": 10.0,
    "entry_spacing": "standard",
    "default_width": 200,
  },
  "git_panel": { "default_width": 200 },
  "terminal": { "default_height": 9999 },
  "unstable.ui_density": "compact",
  // --- ai ---
  "agent_servers": { "qwen-code": { "type": "registry" } },
  "context_servers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "",
      },
    },
    "mcp-server-github": {
      "enabled": true,
      "settings": {
        "github_personal_access_token": "GITHUB_PERSONAL_ACCESS_TOKEN",
      },
    },
  },
  "agent": {
    "default_width": 400,
    "tool_permissions": { "default": "allow" },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "provider": "mistral",
      "model": "codestral-latest",
    },
    "model_parameters": [],
  },
  "edit_predictions": { "mode": "subtle" },
  // --- format ---
  "languages": {
    "Rust": { "format_on_save": "on" },
    "Python": {
      "format_on_save": "on",
      "language_servers": ["ruff", "ty"],
      "formatter": [
        { "language_server": { "name": "ruff" } },
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
      ],
    },
  },
  // --- other ---
  "autosave": "on_focus_change",
  "telemetry": { "diagnostics": false, "metrics": false },
}
