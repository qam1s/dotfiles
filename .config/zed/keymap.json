[
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-enter": "project_panel::OpenPermanent",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-m": "editor::GoToDiagnostic",
      "ctrl-y": "editor::GoToDefinition",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-r": ["task::Spawn", { "task_name": "Run file" }],
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-c": "terminal::Copy",
      "ctrl-v": "terminal::Paste",
      "ctrl-z": ["terminal::SendKeystroke", "ctrl-c"],
    },
  },
]
